@model EasySheba.Models.MedicalTest

@{
    ViewData["Title"] = "Edit Medical Test | EasySheba";
    var days = new[] { "Monday", "Tuesday", "Wednesday", "Thursday", "Friday", "Saturday", "Sunday" };
    var selectedDays = ViewBag.SelectedDays as List<string> ?? new List<string>();
}

<div class="dashboard-wrapper">
    <!-- Hero Section -->
    <div class="hero-section">
        <div class="hero-bg-shapes">
            <div class="shape shape-1"></div>
            <div class="shape shape-2"></div>
            <div class="shape shape-3"></div>
        </div>
        <div class="hero-content">
            <div class="hero-tag">
                <span class="pulse-dot"></span> Hospital Admin
            </div>
            <h1 class="hero-heading">
                Edit <span class="gradient-text">Medical Test</span>
            </h1>
            <p class="hero-subheading">
                Update test details, schedule, and appointment limits.
            </p>
        </div>
    </div>

    <!-- Main Form -->
    <div class="form-container">
        <div class="form-card">
            <div class="form-card-header">
                <div class="header-icon">
                    <i class="fas fa-flask"></i>
                </div>
                <div class="header-text">
                    <h3>Test Information</h3>
                    <p>Update the details below</p>
                </div>
            </div>

            <div class="form-card-body">
                <form asp-action="EditMedicalTest" method="post" enctype="multipart/form-data" id="editTestForm">
                    @Html.AntiForgeryToken()
                    <input type="hidden" asp-for="Id" />
                    <input type="hidden" asp-for="ImagePath" />

                    <!-- Current Image Preview (if exists) -->
                    @if (!string.IsNullOrEmpty(Model.ImagePath))
                    {
                        <div class="form-section">
                            <div class="section-title">
                                <i class="fas fa-image"></i>
                                <h5>Current Image</h5>
                            </div>
                            <div class="current-image-container">
                                <img src="@Model.ImagePath" alt="Test" class="current-image">
                                <div class="form-check mt-3">
                                    <input class="form-check-input" type="checkbox" name="removeImage" id="removeImage" value="true">
                                    <label class="form-check-label text-danger" for="removeImage">
                                        <i class="fas fa-trash"></i> Remove this image
                                    </label>
                                </div>
                            </div>
                        </div>
                    }

                    <!-- Test Details Section -->
                    <div class="form-section">
                        <div class="section-title">
                            <i class="fas fa-microscope"></i>
                            <h5>Test Details</h5>
                        </div>
                        <div class="row">
                            <div class="col-md-6 mb-4">
                                <label asp-for="TestName" class="form-label">Test Name <span class="required">*</span></label>
                                <div class="input-group">
                                    <span class="input-icon"><i class="fas fa-tag"></i></span>
                                    <input asp-for="TestName" class="form-control" />
                                </div>
                                <span asp-validation-for="TestName" class="validation-error"></span>
                            </div>
                            <div class="col-md-6 mb-4">
                                <label asp-for="Price" class="form-label">Test Price (৳) <span class="required">*</span></label>
                                <div class="input-group">
                                    <span class="input-icon"><i class="fas fa-taka-sign"></i></span>
                                    <input asp-for="Price" class="form-control" type="number" min="0" step="0.01" />
                                </div>
                                <span asp-validation-for="Price" class="validation-error"></span>
                            </div>
                            <div class="col-12 mb-4">
                                <label asp-for="Description" class="form-label">Test Description <span class="required">*</span></label>
                                <div class="input-group">
                                    <span class="input-icon"><i class="fas fa-align-left"></i></span>
                                    <textarea asp-for="Description" class="form-control" rows="3"></textarea>
                                </div>
                                <span asp-validation-for="Description" class="validation-error"></span>
                            </div>
                        </div>
                    </div>

                    <!-- Hospital Information Section -->
                    <div class="form-section">
                        <div class="section-title">
                            <i class="fas fa-hospital"></i>
                            <h5>Hospital Information</h5>
                        </div>
                        <div class="row">
                            <div class="col-md-6 mb-4">
                                <label asp-for="HospitalName" class="form-label">Hospital/Clinic Name <span class="required">*</span></label>
                                <div class="input-group">
                                    <span class="input-icon"><i class="fas fa-building"></i></span>
                                    <input asp-for="HospitalName" class="form-control" />
                                </div>
                                <span asp-validation-for="HospitalName" class="validation-error"></span>
                            </div>
                            <div class="col-md-6 mb-4">
                                <label asp-for="HospitalLocation" class="form-label">Hospital Location <span class="required">*</span></label>
                                <div class="input-group">
                                    <span class="input-icon"><i class="fas fa-location-dot"></i></span>
                                    <input asp-for="HospitalLocation" class="form-control" />
                                </div>
                                <span asp-validation-for="HospitalLocation" class="validation-error"></span>
                            </div>
                        </div>
                    </div>

                    <!-- Availability Section -->
                    <div class="form-section">
                        <div class="section-title">
                            <i class="fas fa-calendar-alt"></i>
                            <h5>Availability</h5>
                        </div>
                        <div class="row">
                            <div class="col-12 mb-4">
                                <label class="form-label">Available Days <span class="required">*</span></label>
                                <div class="days-grid">
                                    @foreach (var day in days)
                                    {
                                        <div class="day-checkbox">
                                            <input class="form-check-input" type="checkbox" name="dayList" value="@day" id="day_@day"
                                                   @(selectedDays.Contains(day) ? "checked" : "")>
                                            <label class="form-check-label" for="day_@day">@day</label>
                                        </div>
                                    }
                                </div>
                            </div>
                            <div class="col-md-6 mb-4">
                                <label asp-for="AvailableTime" class="form-label">Available Hours <span class="required">*</span></label>
                                <div class="input-group">
                                    <span class="input-icon"><i class="fas fa-clock"></i></span>
                                    <input asp-for="AvailableTime" class="form-control" />
                                </div>
                                <span asp-validation-for="AvailableTime" class="validation-error"></span>
                            </div>
                        </div>
                    </div>

                    <!-- Appointment Limits Section -->
                    <div class="form-section">
                        <div class="section-title">
                            <i class="fas fa-chart-bar"></i>
                            <h5>Appointment Limits</h5>
                        </div>
                        <div class="row">
                            <div class="col-md-4 mb-4">
                                <label asp-for="DailyAppointmentLimit" class="form-label">Default Daily Limit <span class="required">*</span></label>
                                <div class="input-group">
                                    <span class="input-icon"><i class="fas fa-users"></i></span>
                                    <input asp-for="DailyAppointmentLimit" class="form-control" type="number" min="1" id="defaultLimit" />
                                </div>
                                <div class="field-hint">Default limit for all days</div>
                                <span asp-validation-for="DailyAppointmentLimit" class="validation-error"></span>
                            </div>
                        </div>
                        <div class="alert-modern info">
                            <i class="fas fa-info-circle"></i>
                            <span>You can set specific limits for each day below.</span>
                        </div>
                        <div class="row limit-grid">
                            <div class="col-md-3 mb-3">
                                <label asp-for="MondayLimit" class="form-label">Monday Limit</label>
                                <div class="input-group">
                                    <span class="input-icon"><i class="fas fa-calendar-day"></i></span>
                                    <input asp-for="MondayLimit" class="form-control" type="number" min="0" />
                                </div>
                            </div>
                            <div class="col-md-3 mb-3">
                                <label asp-for="TuesdayLimit" class="form-label">Tuesday Limit</label>
                                <div class="input-group">
                                    <span class="input-icon"><i class="fas fa-calendar-day"></i></span>
                                    <input asp-for="TuesdayLimit" class="form-control" type="number" min="0" />
                                </div>
                            </div>
                            <div class="col-md-3 mb-3">
                                <label asp-for="WednesdayLimit" class="form-label">Wednesday Limit</label>
                                <div class="input-group">
                                    <span class="input-icon"><i class="fas fa-calendar-day"></i></span>
                                    <input asp-for="WednesdayLimit" class="form-control" type="number" min="0" />
                                </div>
                            </div>
                            <div class="col-md-3 mb-3">
                                <label asp-for="ThursdayLimit" class="form-label">Thursday Limit</label>
                                <div class="input-group">
                                    <span class="input-icon"><i class="fas fa-calendar-day"></i></span>
                                    <input asp-for="ThursdayLimit" class="form-control" type="number" min="0" />
                                </div>
                            </div>
                            <div class="col-md-3 mb-3">
                                <label asp-for="FridayLimit" class="form-label">Friday Limit</label>
                                <div class="input-group">
                                    <span class="input-icon"><i class="fas fa-calendar-day"></i></span>
                                    <input asp-for="FridayLimit" class="form-control" type="number" min="0" />
                                </div>
                            </div>
                            <div class="col-md-3 mb-3">
                                <label asp-for="SaturdayLimit" class="form-label">Saturday Limit</label>
                                <div class="input-group">
                                    <span class="input-icon"><i class="fas fa-calendar-day"></i></span>
                                    <input asp-for="SaturdayLimit" class="form-control" type="number" min="0" />
                                </div>
                            </div>
                            <div class="col-md-3 mb-3">
                                <label asp-for="SundayLimit" class="form-label">Sunday Limit</label>
                                <div class="input-group">
                                    <span class="input-icon"><i class="fas fa-calendar-day"></i></span>
                                    <input asp-for="SundayLimit" class="form-control" type="number" min="0" />
                                </div>
                            </div>
                        </div>
                    </div>

                    <!-- Image Upload Section (New Image) -->
                    <div class="form-section">
                        <div class="section-title">
                            <i class="fas fa-cloud-upload-alt"></i>
                            <h5>Change Image (Optional)</h5>
                        </div>
                        <div class="row">
                            <div class="col-12 mb-3">
                                <label asp-for="ImageFile" class="form-label">Upload New Image</label>
                                <div class="file-upload-area" id="imageUploadArea">
                                    <input type="file" name="ImageFile" id="ImageFile" accept="image/*" style="display: none;" />
                                    <div class="upload-preview" id="uploadPreview">
                                        <i class="fas fa-cloud-upload-alt"></i>
                                        <p>Click or drag image to upload</p>
                                        <span class="file-info">PNG, JPG, JPEG up to 2MB</span>
                                    </div>
                                    <div class="preview-image" id="previewImage" style="display: none;">
                                        <img id="testImagePreview" src="#" alt="Preview" />
                                        <button type="button" class="remove-image"><i class="fas fa-times"></i></button>
                                    </div>
                                </div>
                                <div class="field-hint">Leave empty to keep current image</div>
                            </div>
                        </div>
                    </div>

                    <div class="form-actions">
                        <a asp-action="MedicalTests" class="btn-secondary">
                            <i class="fas fa-arrow-left"></i> Back to List
                        </a>
                        <button type="submit" class="btn-primary">
                            <i class="fas fa-save"></i> Update Test
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        $(document).ready(function() {
            // Remove any required validation for ImageFile
            $("#ImageFile").removeAttr("data-val-required");
            $("#ImageFile").removeAttr("data-val");

            // Image upload functionality
            const uploadArea = $('#imageUploadArea');
            const fileInput = $('#ImageFile');
            const previewContainer = $('#previewImage');
            const previewImg = $('#testImagePreview');
            const uploadPreview = $('#uploadPreview');

            uploadArea.on('click', function() {
                fileInput.click();
            });

            fileInput.on('change', function(event) {
                const file = event.target.files[0];
                if (file) {
                    const reader = new FileReader();
                    reader.onload = function(e) {
                        uploadPreview.hide();
                        previewContainer.show();
                        previewImg.attr('src', e.target.result);
                        // If a new image is selected, uncheck remove image checkbox
                        $('#removeImage').prop('checked', false);
                    };
                    reader.readAsDataURL(file);
                }
            });

            $('.remove-image').on('click', function() {
                fileInput.val('');
                previewContainer.hide();
                uploadPreview.show();
            });

            // Drag and drop
            uploadArea.on('dragover', function(e) {
                e.preventDefault();
                $(this).addClass('dragover');
            });
            uploadArea.on('dragleave', function(e) {
                $(this).removeClass('dragover');
            });
            uploadArea.on('drop', function(e) {
                e.preventDefault();
                $(this).removeClass('dragover');
                const files = e.originalEvent.dataTransfer.files;
                if (files.length > 0) {
                    fileInput.prop('files', files);
                    fileInput.trigger('change');
                }
            });

            // Handle remove image checkbox
            $("#removeImage").on("change", function() {
                if ($(this).is(":checked")) {
                    if (!confirm("Are you sure you want to remove the test image? This cannot be undone.")) {
                        $(this).prop("checked", false);
                    } else {
                        // Clear any selected file
                        fileInput.val("");
                        previewContainer.hide();
                        uploadPreview.show();
                    }
                }
            });

            // If a new file is selected, uncheck remove image checkbox
            fileInput.on("change", function() {
                if ($(this).val() !== "") {
                    $("#removeImage").prop("checked", false);
                }
            });

            // Auto-fill day limits with default value
            const defaultLimit = $('#defaultLimit');
            const dayInputs = $('input[id$="Limit"]:not(#defaultLimit)');

            defaultLimit.on('input', function() {
                const defaultValue = $(this).val();
                dayInputs.each(function() {
                    if (!$(this).val() || $(this).val() === '0') {
                        $(this).val(defaultValue);
                    }
                });
            });
        });
    </script>
}

<style>
    /* ========== MODERN STYLES (same as other admin pages) ========== */
    .dashboard-wrapper {
        background: #f5f7fb;
        min-height: 100vh;
    }

    /* Hero Section */
    .hero-section {
        background: linear-gradient(125deg, #ffffff 0%, #f8fafc 100%);
        padding: 60px 5% 80px;
        position: relative;
        overflow: hidden;
    }
    .hero-bg-shapes { position: absolute; top: 0; left: 0; width: 100%; height: 100%; pointer-events: none; }
    .shape { position: absolute; border-radius: 50%; background: rgba(22, 163, 74, 0.03); }
    .shape-1 { width: 400px; height: 400px; top: -150px; right: -100px; }
    .shape-2 { width: 250px; height: 250px; bottom: -80px; left: 10%; background: rgba(22, 163, 74, 0.05); }
    .shape-3 { width: 180px; height: 180px; top: 30%; left: -60px; background: rgba(22, 163, 74, 0.04); }
    .hero-content { max-width: 1100px; margin: 0 auto; position: relative; z-index: 2; text-align: center; }
    .hero-tag { display: inline-flex; align-items: center; gap: 8px; background: rgba(22, 163, 74, 0.1); padding: 6px 18px; border-radius: 40px; font-size: 0.8rem; font-weight: 500; color: #16a34a; margin-bottom: 24px; }
    .pulse-dot { width: 8px; height: 8px; background: #16a34a; border-radius: 50%; display: inline-block; animation: pulse 1.5s infinite; }
    @@keyframes pulse { 0%, 100% { opacity: 1; transform: scale(1); } 50% { opacity: 0.5; transform: scale(1.2); } }
    .hero-heading { font-size: 3.5rem; font-weight: 800; color: #0f172a; margin-bottom: 16px; line-height: 1.2; }
    .gradient-text { background: linear-gradient(135deg, #16a34a, #15803d); -webkit-background-clip: text; -webkit-text-fill-color: transparent; background-clip: text; }
    .hero-subheading { font-size: 1.1rem; color: #5a6e8a; max-width: 550px; margin: 0 auto; }

    /* Form Container */
    .form-container {
        max-width: 900px;
        margin: -40px auto 60px;
        padding: 0 24px;
        position: relative;
        z-index: 2;
    }
    .form-card {
        background: white;
        border-radius: 32px;
        box-shadow: 0 20px 35px -10px rgba(0, 0, 0, 0.08);
        border: 1px solid #eef2f6;
        overflow: hidden;
        transition: all 0.3s ease;
    }
    .form-card-header {
        background: linear-gradient(135deg, #fafef7, #ffffff);
        padding: 28px 32px;
        display: flex;
        align-items: center;
        gap: 16px;
        border-bottom: 1px solid #eef2f0;
    }
    .header-icon {
        width: 48px;
        height: 48px;
        background: #e6f7ec;
        border-radius: 24px;
        display: flex;
        align-items: center;
        justify-content: center;
    }
    .header-icon i { font-size: 24px; color: #16a34a; }
    .header-text h3 { font-size: 1.3rem; font-weight: 700; color: #0a2f1f; margin: 0 0 4px 0; }
    .header-text p { font-size: 0.85rem; color: #64748b; margin: 0; }
    .form-card-body { padding: 32px; }

    /* Form Sections */
    .form-section {
        margin-bottom: 36px;
        padding-bottom: 24px;
        border-bottom: 1px solid #eef2f0;
    }
    .form-section:last-child {
        border-bottom: none;
        margin-bottom: 0;
        padding-bottom: 0;
    }
    .section-title {
        display: flex;
        align-items: center;
        gap: 12px;
        margin-bottom: 24px;
    }
    .section-title i {
        width: 32px;
        height: 32px;
        background: #e6f7ec;
        border-radius: 10px;
        display: flex;
        align-items: center;
        justify-content: center;
        color: #16a34a;
        font-size: 1rem;
    }
    .section-title h5 { font-size: 1rem; font-weight: 700; color: #0a2f1f; margin: 0; }

    /* Form Elements */
    .form-label {
        display: block;
        font-size: 0.85rem;
        font-weight: 600;
        color: #0a2f1f;
        margin-bottom: 8px;
    }
    .required { color: #dc2626; }
    .input-group {
        display: flex;
        align-items: center;
        border: 1px solid #e2e8f0;
        border-radius: 12px;
        background: #fafef7;
        transition: all 0.2s;
    }
    .input-group:focus-within {
        border-color: #16a34a;
        box-shadow: 0 0 0 3px rgba(22, 163, 74, 0.1);
    }
    .input-icon { padding: 0 14px; color: #94a3b8; }
    .form-control {
        flex: 1;
        padding: 12px 0;
        border: none;
        background: transparent;
        font-size: 0.95rem;
        outline: none;
    }
    textarea.form-control { resize: vertical; min-height: 80px; }
    .validation-error { font-size: 0.75rem; color: #dc2626; margin-top: 4px; display: block; }
    .field-hint { font-size: 0.7rem; color: #94a3b8; margin-top: 6px; display: flex; align-items: center; gap: 4px; }

    /* Days Grid */
    .days-grid {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(100px, 1fr));
        gap: 12px;
        background: #fafef7;
        border-radius: 12px;
        padding: 16px;
        border: 1px solid #eef2f0;
    }
    .day-checkbox {
        display: flex;
        align-items: center;
        gap: 8px;
    }
    .form-check-input {
        width: 1em;
        height: 1em;
        margin-top: 0;
        background-color: #fff;
        border: 1px solid #cbd5e1;
        border-radius: 0.25rem;
        cursor: pointer;
    }
    .form-check-input:checked {
        background-color: #16a34a;
        border-color: #16a34a;
        background-image: url("data:image/svg+xml,%3csvg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 20 20'%3e%3cpath fill='none' stroke='%23fff' stroke-linecap='round' stroke-linejoin='round' stroke-width='3' d='M6 10l3 3l6-6'/%3e%3c/svg%3e");
    }
    .form-check-label {
        font-size: 0.85rem;
        color: #1e293b;
        cursor: pointer;
    }

    /* Limit Grid */
    .limit-grid {
        margin-top: 16px;
    }

    /* Alert */
    .alert-modern {
        display: flex;
        align-items: center;
        gap: 12px;
        padding: 14px 20px;
        border-radius: 16px;
        margin-bottom: 24px;
        background: #eff6ff;
        border-left: 4px solid #3b82f6;
        color: #1e40af;
    }
    .alert-modern.info {
        background: #eff6ff;
        border-left-color: #3b82f6;
    }

    /* Current Image */
    .current-image-container {
        text-align: center;
        margin-bottom: 16px;
    }
    .current-image {
        max-width: 150px;
        max-height: 150px;
        border-radius: 12px;
        object-fit: cover;
        border: 1px solid #eef2f0;
        box-shadow: 0 2px 8px rgba(0,0,0,0.05);
    }

    /* File Upload */
    .file-upload-area {
        border: 2px dashed #e2e8f0;
        border-radius: 16px;
        background: #fafef7;
        cursor: pointer;
        transition: all 0.2s;
        min-height: 160px;
        display: flex;
        align-items: center;
        justify-content: center;
        position: relative;
        overflow: hidden;
    }
    .file-upload-area.dragover {
        border-color: #16a34a;
        background: #e6f7ec;
    }
    .upload-preview {
        text-align: center;
        padding: 32px;
    }
    .upload-preview i {
        font-size: 48px;
        color: #94a3b8;
        margin-bottom: 12px;
        display: block;
    }
    .upload-preview p {
        font-size: 0.85rem;
        color: #475569;
        margin: 0;
    }
    .file-info {
        font-size: 0.7rem;
        color: #94a3b8;
        display: block;
        margin-top: 8px;
    }
    .preview-image {
        position: relative;
        width: 100%;
        max-height: 200px;
        overflow: hidden;
        display: flex;
        justify-content: center;
        align-items: center;
        background: #f8fafc;
    }
    .preview-image img {
        max-width: 100%;
        max-height: 180px;
        object-fit: contain;
    }
    .remove-image {
        position: absolute;
        top: 8px;
        right: 8px;
        background: rgba(0,0,0,0.6);
        border: none;
        border-radius: 50%;
        width: 28px;
        height: 28px;
        display: flex;
        align-items: center;
        justify-content: center;
        color: white;
        cursor: pointer;
        transition: all 0.2s;
    }
    .remove-image:hover { background: #dc2626; }

    /* Buttons */
    .form-actions {
        display: flex;
        justify-content: flex-end;
        gap: 16px;
        margin-top: 32px;
        padding-top: 24px;
        border-top: 1px solid #eef2f0;
    }
    .btn-primary, .btn-secondary {
        display: inline-flex;
        align-items: center;
        gap: 8px;
        padding: 12px 28px;
        border-radius: 12px;
        font-weight: 600;
        font-size: 0.9rem;
        transition: all 0.3s ease;
        text-decoration: none;
        cursor: pointer;
        border: none;
    }
    .btn-primary {
        background: #16a34a;
        color: white;
        box-shadow: 0 4px 8px rgba(22, 163, 74, 0.2);
    }
    .btn-primary:hover {
        background: #15803d;
        transform: translateY(-2px);
        box-shadow: 0 8px 16px rgba(22, 163, 74, 0.3);
    }
    .btn-secondary {
