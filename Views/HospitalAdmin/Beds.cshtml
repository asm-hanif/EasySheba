@model IEnumerable<EasySheba.Models.Bed>

@{
    ViewData["Title"] = "Manage Beds | EasySheba";
    var totalBeds = Model.Sum(b => b.TotalBeds ?? 0);
    var availableBeds = Model.Sum(b => b.AvailableBeds ?? 0);
    var occupiedBeds = totalBeds - availableBeds;
    var occupancyPercent = totalBeds > 0 ? (occupiedBeds * 100) / totalBeds : 0;
}

<div class="dashboard-wrapper">
    <!-- Hero Section -->
    <div class="hero-section">
        <div class="hero-bg-shapes">
            <div class="shape shape-1"></div>
            <div class="shape shape-2"></div>
            <div class="shape shape-3"></div>
        </div>
        <div class="hero-content">
            <div class="hero-tag">
                <span class="pulse-dot"></span> Hospital Admin
            </div>
            <h1 class="hero-heading">
                Manage <span class="gradient-text">Hospital Beds</span>
            </h1>
            <p class="hero-subheading">
                Add, edit, or remove bed listings for your hospital.
            </p>
        </div>
    </div>

    <!-- Main Content -->
    <div class="dashboard-main">
        <!-- Alerts -->
        @if (TempData["success"] != null)
        {
            <div class="alert-modern success">
                <i class="fas fa-check-circle"></i>
                <span>@TempData["success"]</span>
                <button class="alert-close" onclick="this.parentElement.remove()">×</button>
            </div>
        }
        @if (TempData["error"] != null)
        {
            <div class="alert-modern error">
                <i class="fas fa-exclamation-circle"></i>
                <span>@TempData["error"]</span>
                <button class="alert-close" onclick="this.parentElement.remove()">×</button>
            </div>
        }

        <!-- Stats Cards -->
        <div class="stats-grid">
            <div class="stat-card-modern">
                <div class="stat-icon-bg">
                    <i class="fas fa-bed"></i>
                </div>
                <div class="stat-content">
                    <h3 class="stat-number">@totalBeds</h3>
                    <p class="stat-label">Total Beds</p>
                </div>
            </div>
            <div class="stat-card-modern">
                <div class="stat-icon-bg" style="background:#e6f7ec;">
                    <i class="fas fa-check-circle" style="color:#16a34a;"></i>
                </div>
                <div class="stat-content">
                    <h3 class="stat-number">@availableBeds</h3>
                    <p class="stat-label">Available Beds</p>
                    <span class="stat-trend success">Ready to book</span>
                </div>
            </div>
            <div class="stat-card-modern">
                <div class="stat-icon-bg" style="background:#fee2e2;">
                    <i class="fas fa-user-injured" style="color:#dc2626;"></i>
                </div>
                <div class="stat-content">
                    <h3 class="stat-number">@occupiedBeds</h3>
                    <p class="stat-label">Occupied Beds</p>
                    <span class="stat-trend danger">In use</span>
                </div>
            </div>
            <div class="stat-card-modern">
                <div class="stat-icon-bg" style="background:#fef3c7;">
                    <i class="fas fa-chart-line" style="color:#d97706;"></i>
                </div>
                <div class="stat-content">
                    <h3 class="stat-number">@occupancyPercent%</h3>
                    <p class="stat-label">Occupancy Rate</p>
                    <div class="progress-bar-mini">
                        <div class="progress-fill" style="width: @occupancyPercent%;"></div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Header with Add Button -->
        <div class="page-header">
            <div class="header-left">
                <h2 class="page-title">
                    <i class="fas fa-bed"></i> Bed Listings
                </h2>
                <p class="page-subtitle">Manage all bed types and availability</p>
            </div>
            <a asp-action="AddBed" class="btn-primary">
                <i class="fas fa-plus-circle"></i> Add New Bed
            </a>
        </div>

        <!-- Beds Grid -->
        @if (!Model.Any())
        {
            <div class="empty-modern">
                <div class="empty-icon">
                    <i class="fas fa-bed"></i>
                </div>
                <h3>No beds added yet</h3>
                <p>Click the button above to add beds to your hospital.</p>
            </div>
        }
        else
        {
            <div class="doctors-grid-modern" id="bedsGrid">
                @foreach (var bed in Model)
                {
                    var avail = bed.AvailableBeds ?? 0;
                    var total = bed.TotalBeds ?? 0;
                    var priceText = bed.PricePerDay.HasValue ? ("৳" + bed.PricePerDay.Value.ToString("0.##") + "/day") : "N/A";
                    var occupancyPercentBed = total > 0 ? ((total - avail) * 100) / total : 0;

                    <div class="bed-card-modern">
                        <div class="bed-image">
                            @if (!string.IsNullOrEmpty(bed.ImagePath))
                            {
                                <img src="@bed.ImagePath" alt="@bed.BedType">
                            }
                            else
                            {
                                <div class="image-placeholder">
                                    <i class="fas fa-bed"></i>
                                </div>
                            }
                            <div class="price-tag">
                                <i class="fas fa-tag"></i> @priceText
                            </div>
                        </div>
                        <div class="bed-content">
                            <div class="bed-header">
                                <h3 class="bed-type">@bed.BedType</h3>
                                <div class="availability-badge @(avail > 0 ? "available" : "unavailable")">
                                    <i class="fas @(avail > 0 ? "fa-check-circle" : "fa-times-circle")"></i>
                                    @avail / @total Available
                                </div>
                            </div>
                            <div class="bed-amenities">
                                <span class="amenity-badge">@(string.IsNullOrEmpty(bed.AcNonAc) ? "Standard" : bed.AcNonAc)</span>
                                @if (bed.AttachedBathroom == true)
                                {
                                    <span class="amenity-badge"><i class="fas fa-bath"></i> Attached Bath</span>
                                }
                                @if (bed.TvAvailable == true)
                                {
                                    <span class="amenity-badge"><i class="fas fa-tv"></i> TV</span>
                                }
                                @if (bed.WifiAvailable == true)
                                {
                                    <span class="amenity-badge"><i class="fas fa-wifi"></i> WiFi</span>
                                }
                            </div>
                            <div class="bed-location">
                                <div class="hospital-info">
                                    <i class="fas fa-hospital"></i>
                                    <span>@bed.HospitalName</span>
                                </div>
                                <div class="location-info">
                                    <i class="fas fa-map-marker-alt"></i>
                                    <span>@bed.HospitalLocation</span>
                                </div>
                            </div>
                            <div class="occupancy-progress">
                                <div class="progress-label">
                                    <span>Occupancy</span>
                                    <span>@occupancyPercentBed%</span>
                                </div>
                                <div class="progress-track">
                                    <div class="progress-fill" style="width: @occupancyPercentBed%; background: @(occupancyPercentBed > 80 ? "#dc2626" : occupancyPercentBed > 50 ? "#f59e0b" : "#16a34a");"></div>
                                </div>
                            </div>
                            <div class="bed-actions">
                                <a asp-action="EditBed" asp-route-id="@bed.Id" class="btn-edit">
                                    <i class="fas fa-edit"></i> Edit
                                </a>
                                <button onclick="deleteBed(@bed.Id)" class="btn-delete">
                                    <i class="fas fa-trash"></i> Delete
                                </button>
                            </div>
                        </div>
                    </div>
                }
            </div>
        }
    </div>
</div>

<!-- Delete Modal -->
<div class="modal fade" id="deleteModal" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content-modern">
            <div class="modal-header-modern">
                <h5 class="modal-title">Confirm Delete</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body-modern">
                <i class="fas fa-exclamation-triangle"></i>
                <p>Are you sure you want to delete this bed? This action cannot be undone.</p>
            </div>
            <div class="modal-footer-modern">
                <button type="button" class="btn-secondary" data-bs-dismiss="modal">Cancel</button>
                <form id="deleteForm" method="post" asp-action="DeleteBed">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="id" id="deleteId" />
                    <button type="submit" class="btn-danger">Delete</button>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        function deleteBed(id) {
            document.getElementById('deleteId').value = id;
            new bootstrap.Modal(document.getElementById('deleteModal')).show();
        }
    </script>
}

<style>
    /* ========== MODERN STYLES (matching other admin pages) ========== */
    .dashboard-wrapper {
        background: #f5f7fb;
        min-height: 100vh;
    }

    /* Hero Section */
    .hero-section {
        background: linear-gradient(125deg, #ffffff 0%, #f8fafc 100%);
        padding: 60px 5% 80px;
        position: relative;
        overflow: hidden;
    }
    .hero-bg-shapes {
        position: absolute;
        top: 0;
        left: 0;
        width: 100%;
        height: 100%;
        pointer-events: none;
    }
    .shape {
        position: absolute;
        border-radius: 50%;
        background: rgba(22, 163, 74, 0.03);
    }
    .shape-1 { width: 400px; height: 400px; top: -150px; right: -100px; }
    .shape-2 { width: 250px; height: 250px; bottom: -80px; left: 10%; background: rgba(22, 163, 74, 0.05); }
    .shape-3 { width: 180px; height: 180px; top: 30%; left: -60px; background: rgba(22, 163, 74, 0.04); }
    .hero-content {
        max-width: 1100px;
        margin: 0 auto;
        position: relative;
        z-index: 2;
        text-align: center;
    }
    .hero-tag {
        display: inline-flex;
        align-items: center;
        gap: 8px;
        background: rgba(22, 163, 74, 0.1);
        padding: 6px 18px;
        border-radius: 40px;
        font-size: 0.8rem;
        font-weight: 500;
        color: #16a34a;
        margin-bottom: 24px;
    }
    .pulse-dot {
        width: 8px;
        height: 8px;
        background: #16a34a;
        border-radius: 50%;
        display: inline-block;
        animation: pulse 1.5s infinite;
    }
    @@keyframes pulse {
        0%, 100% { opacity: 1; transform: scale(1); }
        50% { opacity: 0.5; transform: scale(1.2); }
    }
    .hero-heading {
        font-size: 3.5rem;
        font-weight: 800;
        color: #0f172a;
        margin-bottom: 16px;
        line-height: 1.2;
    }
    .gradient-text {
        background: linear-gradient(135deg, #16a34a, #15803d);
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
        background-clip: text;
    }
    .hero-subheading {
        font-size: 1.1rem;
        color: #5a6e8a;
        max-width: 550px;
        margin: 0 auto;
    }

    /* Main Content */
    .dashboard-main {
        max-width: 1300px;
        margin: -40px auto 60px;
        padding: 0 24px 60px;
        position: relative;
        z-index: 2;
    }

    /* Alerts */
    .alert-modern {
        display: flex;
        align-items: center;
        gap: 12px;
        padding: 14px 20px;
        border-radius: 16px;
        margin-bottom: 24px;
        animation: slideIn 0.3s ease;
    }
    @@keyframes slideIn {
        from { transform: translateY(-10px); opacity: 0; }
        to { transform: translateY(0); opacity: 1; }
    }
    .alert-modern.success {
        background: #e8f5e9;
        border-left: 4px solid #16a34a;
        color: #1e7b3a;
    }
    .alert-modern.error {
        background: #ffebee;
        border-left: 4px solid #ef4444;
        color: #b91c1c;
    }
    .alert-close {
        margin-left: auto;
        background: none;
        border: none;
        font-size: 1.2rem;
        cursor: pointer;
        color: inherit;
        opacity: 0.6;
    }

    /* Stats Cards */
    .stats-grid {
        display: grid;
        grid-template-columns: repeat(4, 1fr);
        gap: 24px;
        margin-bottom: 48px;
    }
    .stat-card-modern {
        background: white;
        border-radius: 24px;
        padding: 20px;
        transition: all 0.3s cubic-bezier(0.25, 0.8, 0.25, 1);
        box-shadow: 0 2px 8px rgba(0, 0, 0, 0.02);
        border: 1px solid #eef2f6;
        display: flex;
        align-items: center;
        gap: 16px;
    }
    .stat-card-modern:hover {
        transform: translateY(-4px);
        box-shadow: 0 20px 35px -12px rgba(0, 0, 0, 0.12);
        border-color: rgba(22, 163, 74, 0.2);
    }
    .stat-icon-bg {
        width: 56px;
        height: 56px;
        background: #e8f5e9;
        border-radius: 18px;
        display: flex;
        align-items: center;
        justify-content: center;
        flex-shrink: 0;
    }
    .stat-icon-bg i {
        font-size: 28px;
        color: #16a34a;
    }
    .stat-content {
        flex: 1;
    }
    .stat-number {
        font-size: 2rem;
        font-weight: 800;
        color: #0f172a;
        margin-bottom: 4px;
    }
    .stat-label {
        font-size: 0.85rem;
        color: #64748b;
        margin-bottom: 6px;
    }
    .stat-trend {
        font-size: 0.7rem;
        display: inline-flex;
        align-items: center;
        gap: 4px;
        padding: 2px 8px;
        border-radius: 20px;
        background: #f1f5f9;
    }
    .stat-trend.success { color: #16a34a; background: #e8f5e9; }
    .stat-trend.danger { color: #dc2626; background: #fee2e2; }
    .progress-bar-mini {
        background: #e2e8f0;
        border-radius: 20px;
        height: 4px;
        overflow: hidden;
        margin-top: 8px;
    }
    .progress-fill {
        height: 100%;
        background: #16a34a;
        border-radius: 20px;
        transition: width 0.3s;
    }

    /* Page Header */
    .page-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        flex-wrap: wrap;
        gap: 20px;
        margin-bottom: 32px;
        padding-bottom: 16px;
        border-bottom: 1px solid #e2e8f0;
    }
    .header-left {
        flex: 1;
    }
    .page-title {
        font-size: 1.5rem;
        font-weight: 700;
        color: #0f172a;
        margin-bottom: 4px;
        display: flex;
        align-items: center;
        gap: 8px;
    }
    .page-title i {
        color: #16a34a;
    }
    .page-subtitle {
        font-size: 0.85rem;
        color: #64748b;
        margin: 0;
    }
    .btn-primary {
        display: inline-flex;
        align-items: center;
        gap: 8px;
        padding: 10px 24px;
        background: #16a34a;
        color: white;
        border-radius: 12px;
        font-weight: 600;
        text-decoration: none;
        transition: all 0.3s ease;
        border: none;
        cursor: pointer;
    }
    .btn-primary:hover {
        background: #15803d;
        transform: translateY(-2px);
        box-shadow: 0 8px 16px rgba(22, 163, 74, 0.3);
    }

    /* Bed Cards Grid */
    .doctors-grid-modern {
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: 32px;
        align-items: stretch;
    }
    .bed-card-modern {
        background: white;
        border-radius: 28px;
        overflow: hidden;
        transition: all 0.3s cubic-bezier(0.25, 0.8, 0.25, 1);
        box-shadow: 0 2px 8px rgba(0, 0, 0, 0.02);
        border: 1px solid #eef2f6;
        display: flex;
        flex-direction: column;
        height: 100%;
    }
    .bed-card-modern:hover {
        transform: translateY(-8px);
        box-shadow: 0 20px 35px -12px rgba(0, 0, 0, 0.12);
        border-color: rgba(22, 163, 74, 0.2);
    }

    /* Bed Image */
    .bed-image {
        position: relative;
        height: 200px;
        overflow: hidden;
        background: #f1f5f9;
    }
    .bed-image img {
        width: 100%;
        height: 100%;
        object-fit: cover;
        transition: transform 0.3s;
    }
    .bed-card-modern:hover .bed-image img {
        transform: scale(1.05);
    }
    .image-placeholder {
        width: 100%;
        height: 100%;
        display: flex;
        align-items: center;
        justify-content: center;
        background: #e6f7ec;
    }
    .image-placeholder i {
        font-size: 64px;
        color: #16a34a;
    }
    .price-tag {
        position: absolute;
        top: 12px;
        right: 12px;
        background: rgba(0, 0, 0, 0.7);
        backdrop-filter: blur(4px);
        color: white;
        padding: 4px 12px;
        border-radius: 30px;
        font-size: 0.8rem;
        font-weight: 600;
        display: flex;
        align-items: center;
        gap: 4px;
    }

    /* Bed Content */
    .bed-content {
        padding: 20px;
        flex: 1;
        display: flex;
        flex-direction: column;
        gap: 12px;
    }
    .bed-header {
        display: flex;
        justify-content: space-between;
        align-items: flex-start;
        flex-wrap: wrap;
        gap: 10px;
    }
    .bed-type {
        font-size: 1.1rem;
        font-weight: 700;
        color: #0f172a;
        margin: 0;
    }
    .availability-badge {
        display: inline-flex;
        align-items: center;
        gap: 4px;
        padding: 4px 10px;
        border-radius: 30px;
        font-size: 0.7rem;
        font-weight: 600;
    }
    .availability-badge.available {
        background: #e6f7ec;
        color: #16a34a;
    }
    .availability-badge.unavailable {
        background: #fee2e2;
        color: #dc2626;
    }
    .bed-amenities {
        display: flex;
        flex-wrap: wrap;
        gap: 8px;
    }
    .amenity-badge {
        background: #f1f5f9;
        padding: 4px 10px;
        border-radius: 20px;
        font-size: 0.7rem;
        color: #475569;
        display: inline-flex;
        align-items: center;
        gap: 4px;
    }
    .bed-location {
        display: flex;
        flex-direction: column;
        gap: 6px;
        font-size: 0.8rem;
        color: #475569;
        background: #fafef7;
        padding: 10px;
        border-radius: 12px;
    }
    .hospital-info, .location-info {
        display: flex;
        align-items: center;
        gap: 8px;
    }
    .hospital-info i, .location-info i {
        width: 18px;
        color: #16a34a;
    }
    .occupancy-progress {
        margin: 8px 0;
    }
    .progress-label {
        display: flex;
        justify-content: space-between;
        font-size: 0.7rem;
        color: #64748b;
        margin-bottom: 4px;
    }
    .progress-track {
        background: #e2e8f0;
        border-radius: 20px;
        height: 6px;
        overflow: hidden;
    }
    .progress-fill {
        height: 100%;
        border-radius: 20px;
        transition: width 0.3s;
    }
    .bed-actions {
        display: flex;
        gap: 12px;
        margin-top: 8px;
    }
    .btn-edit, .btn-delete {
        flex: 1;
        padding: 8px;
        border-radius: 10px;
        font-size: 0.8rem;
        font-weight: 600;
        text-align: center;
        text-decoration: none;
        transition: all 0.2s;
        border: none;
        cursor: pointer;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        gap: 6px;
    }
    .btn-edit {
        background: #e6f7ec;
        color: #16a34a;
        border: 1px solid #16a34a;
    }
    .btn-edit:hover {
        background: #16a34a;
        color: white;
        transform: translateY(-2px);
    }
    .btn-delete {
        background: #fee2e2;
        color: #dc2626;
        border: 1px solid #dc2626;
    }
    .btn-delete:hover {
        background: #dc2626;
        color: white;
        transform: translateY(-2px);
    }

    /* Empty State */
    .empty-modern {
        text-align: center;
        padding: 80px 20px;
        background: white;
        border-radius: 32px;
        margin-top: 40px;
    }
    .empty-icon {
        width: 80px;
        height: 80px;
        background: #f1f5f9;
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        margin: 0 auto 20px;
        font-size: 2.5rem;
        color: #94a3b8;
    }
    .empty-modern h3 {
        font-size: 1.3rem;
        color: #334155;
        margin-bottom: 8px;
    }
    .empty-modern p {
        color: #64748b;
    }

    /* Modal Modern */
    .modal-content-modern {
        background: white;
        border-radius: 24px;
        border: none;
        overflow: hidden;
    }
    .modal-header-modern {
        padding: 20px 24px;
        border-bottom: 1px solid #eef2f0;
        display: flex;
        justify-content: space-between;
        align-items: center;
    }
    .modal-header-modern .modal-title {
        font-size: 1.2rem;
        font-weight: 700;
        color: #0f172a;
    }
    .modal-body-modern {
        padding: 24px;
        text-align: center;
    }
    .modal-body-modern i {
        font-size: 48px;
        color: #f59e0b;
        margin-bottom: 12px;
        display: block;
    }
    .modal-body-modern p {
        font-size: 0.95rem;
        color: #475569;
        margin: 0;
    }
    .modal-footer-modern {
        padding: 16px 24px;
        border-top: 1px solid #eef2f0;
        display: flex;
        justify-content: flex-end;
        gap: 12px;
    }
    .btn-danger {
        background: #dc2626;
        color: white;
        border: none;
        padding: 8px 20px;
        border-radius: 10px;
        font-weight: 600;
        transition: all 0.2s;
    }
    .btn-danger:hover {
        background: #b91c1c;
        transform: translateY(-2px);
    }
    .btn-secondary {
        background: white;
        border: 1px solid #e2e8f0;
        color: #475569;
        padding: 8px 20px;
        border-radius: 10px;
        font-weight: 600;
        transition: all 0.2s;
    }
    .btn-secondary:hover {
        border-color: #16a34a;
        color: #16a34a;
    }

    /* Responsive */
    @@media (max-width: 1100px) {
        .stats-grid {
            grid-template-columns: repeat(2, 1fr);
        }
        .doctors-grid-modern {
            grid-template-columns: repeat(2, 1fr);
        }
    }
    @@media (max-width: 768px) {
        .hero-heading {
            font-size: 2rem;
        }
        .stats-grid {
            grid-template-columns: 1fr;
        }
        .doctors-grid-modern {
            grid-template-columns: 1fr;
        }
        .page-header {
            flex-direction: column;
            align-items: stretch;
        }
        .btn-primary {
            justify-content: center;
        }
    }
</style>