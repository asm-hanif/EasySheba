@model EasySheba.Models.HospitalAdminProfile

@{
    ViewData["Title"] = "Hospital Details | EasySheba";
}

<div class="dashboard-wrapper">
    <!-- Hero Section -->
    <div class="hero-section">
        <div class="hero-bg-shapes">
            <div class="shape shape-1"></div>
            <div class="shape shape-2"></div>
            <div class="shape shape-3"></div>
        </div>
        <div class="hero-content">
            <div class="hero-tag">
                <span class="pulse-dot"></span> Super Admin
            </div>
            <h1 class="hero-heading">
                Hospital <span class="gradient-text">Details</span>
            </h1>
            <p class="hero-subheading">
                Review hospital registration and approve or reject.
            </p>
        </div>
    </div>

    <!-- Main Content -->
    <div class="dashboard-main">
        <div class="form-container" style="max-width: 800px;">
            <div class="form-card">
                <div class="form-card-header">
                    <div class="header-icon">
                        <i class="fas fa-hospital"></i>
                    </div>
                    <div class="header-text">
                        <h3>@Model.HospitalName</h3>
                        <p>Hospital Information</p>
                    </div>
                </div>

                <div class="form-card-body">
                    <!-- Details Grid -->
                    <div class="details-grid">
                        <div class="detail-card">
                            <i class="fas fa-phone-alt"></i>
                            <div>
                                <label>Contact Number</label>
                                <p>@Model.ContactNumber</p>
                            </div>
                        </div>
                        <div class="detail-card">
                            <i class="fas fa-id-card"></i>
                            <div>
                                <label>User ID</label>
                                <p class="text-truncate" title="@Model.UserId">@Model.UserId</p>
                            </div>
                        </div>
                        <div class="detail-card">
                            <i class="fas @(Model.IsApproved ? "fa-check-circle" : "fa-clock")"></i>
                            <div>
                                <label>Status</label>
                                <p>
                                    @if (Model.IsApproved)
                                    {
                                        <span class="status-badge approved">Approved</span>
                                    }
                                    else
                                    {
                                        <span class="status-badge pending">Pending</span>
                                    }
                                </p>
                            </div>
                        </div>
                    </div>

                    <!-- Documents Section -->
                    @if (!string.IsNullOrEmpty(Model.DocumentsPath))
                    {
                        <div class="documents-section">
                            <div class="section-title" style="margin-bottom: 20px;">
                                <i class="fas fa-file-alt"></i>
                                <h5>Uploaded Documents</h5>
                            </div>
                            <div class="document-list">
                                @{
                                    var docs = Model.DocumentsPath.Split(new[] { ',' }, StringSplitOptions.RemoveEmptyEntries);
                                }
                                @foreach (var doc in docs)
                                {
                                    if (!string.IsNullOrWhiteSpace(doc))
                                    {
                                        <a href="/uploads/@doc.Trim()" target="_blank" class="document-item">
                                            <i class="fas fa-file-pdf text-danger"></i>
                                            <span class="filename">@doc.Trim()</span>
                                            <i class="fas fa-download"></i>
                                        </a>
                                    }
                                }
                            </div>
                        </div>
                    }

                    <!-- Action Buttons -->
                    <div class="form-actions">
                        <a asp-action="Requests" class="btn-secondary">
                            <i class="fas fa-arrow-left"></i> Back to Requests
                        </a>

                        @if (!Model.IsApproved)
                        {
                            <div class="action-buttons-group">
                                <form asp-action="Approve" method="post" class="d-inline">
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="id" value="@Model.Id" />
                                    <button type="submit" class="btn-approve">
                                        <i class="fas fa-check-circle"></i> Approve
                                    </button>
                                </form>
                                <form asp-action="Reject" method="post" class="d-inline">
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="id" value="@Model.Id" />
                                    <button type="submit" class="btn-reject" onclick="return confirm('Are you sure you want to reject this hospital?')">
                                        <i class="fas fa-times-circle"></i> Reject
                                    </button>
                                </form>
                            </div>
                        }
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<style>
    /* ========== MODERN STYLES (same as other admin pages) ========== */
    .dashboard-wrapper {
        background: #f5f7fb;
        min-height: 100vh;
    }

    /* Hero Section */
    .hero-section {
        background: linear-gradient(125deg, #ffffff 0%, #f8fafc 100%);
        padding: 60px 5% 80px;
        position: relative;
        overflow: hidden;
    }
    .hero-bg-shapes { position: absolute; top: 0; left: 0; width: 100%; height: 100%; pointer-events: none; }
    .shape { position: absolute; border-radius: 50%; background: rgba(22, 163, 74, 0.03); }
    .shape-1 { width: 400px; height: 400px; top: -150px; right: -100px; }
    .shape-2 { width: 250px; height: 250px; bottom: -80px; left: 10%; background: rgba(22, 163, 74, 0.05); }
    .shape-3 { width: 180px; height: 180px; top: 30%; left: -60px; background: rgba(22, 163, 74, 0.04); }
    .hero-content {
        max-width: 1100px;
        margin: 0 auto;
        position: relative;
        z-index: 2;
        text-align: center;
    }
    .hero-tag {
        display: inline-flex;
        align-items: center;
        gap: 8px;
        background: rgba(22, 163, 74, 0.1);
        padding: 6px 18px;
        border-radius: 40px;
        font-size: 0.8rem;
        font-weight: 500;
        color: #16a34a;
        margin-bottom: 24px;
    }
    .pulse-dot {
        width: 8px;
        height: 8px;
        background: #16a34a;
        border-radius: 50%;
        display: inline-block;
        animation: pulse 1.5s infinite;
    }
    @@keyframes pulse {
        0%, 100% { opacity: 1; transform: scale(1); }
        50% { opacity: 0.5; transform: scale(1.2); }
    }
    .hero-heading {
        font-size: 3.5rem;
        font-weight: 800;
        color: #0f172a;
        margin-bottom: 16px;
        line-height: 1.2;
    }
    .gradient-text {
        background: linear-gradient(135deg, #16a34a, #15803d);
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
        background-clip: text;
    }
    .hero-subheading {
        font-size: 1.1rem;
        color: #5a6e8a;
        max-width: 550px;
        margin: 0 auto;
    }

    /* Main Content */
    .dashboard-main {
        max-width: 1300px;
        margin: 0 auto;
        padding: 40px 24px 60px;
    }
    .form-container {
        margin: -40px auto 60px;
        padding: 0 24px;
        position: relative;
        z-index: 2;
    }

    /* Form Card (reused) */
    .form-card {
        background: white;
        border-radius: 32px;
        box-shadow: 0 20px 35px -10px rgba(0, 0, 0, 0.08);
        border: 1px solid #eef2f6;
        overflow: hidden;
        transition: all 0.3s ease;
    }
    .form-card-header {
        background: linear-gradient(135deg, #fafef7, #ffffff);
        padding: 28px 32px;
        display: flex;
        align-items: center;
        gap: 16px;
        border-bottom: 1px solid #eef2f0;
    }
    .header-icon {
        width: 48px;
        height: 48px;
        background: #e6f7ec;
        border-radius: 24px;
        display: flex;
        align-items: center;
        justify-content: center;
    }
    .header-icon i { font-size: 24px; color: #16a34a; }
    .header-text h3 { font-size: 1.3rem; font-weight: 700; color: #0a2f1f; margin: 0 0 4px 0; }
    .header-text p { font-size: 0.85rem; color: #64748b; margin: 0; }
    .form-card-body {
        padding: 32px;
    }

    /* Details Grid */
    .details-grid {
        display: grid;
        grid-template-columns: repeat(2, 1fr);
        gap: 20px;
        margin-bottom: 32px;
    }
    .detail-card {
        background: #fafef7;
        border: 1px solid #eef2f0;
        border-radius: 20px;
        padding: 20px;
        display: flex;
        align-items: center;
        gap: 16px;
        transition: all 0.2s;
    }
    .detail-card:hover {
        transform: translateY(-2px);
        border-color: #16a34a;
        box-shadow: 0 4px 12px rgba(22, 163, 74, 0.05);
    }
    .detail-card i {
        width: 48px;
        height: 48px;
        background: white;
        border-radius: 16px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 22px;
        color: #16a34a;
        box-shadow: 0 2px 6px rgba(0,0,0,0.02);
    }
    .detail-card label {
        font-size: 0.7rem;
        text-transform: uppercase;
        font-weight: 600;
        color: #94a3b8;
        letter-spacing: 0.5px;
        margin-bottom: 4px;
        display: block;
    }
    .detail-card p {
        font-size: 0.95rem;
        font-weight: 600;
        color: #1e293b;
        margin: 0;
    }
    .status-badge {
        display: inline-flex;
        align-items: center;
        gap: 6px;
        padding: 4px 12px;
        border-radius: 30px;
        font-size: 0.75rem;
        font-weight: 600;
    }
    .status-badge.approved {
        background: #e6f7ec;
        color: #16a34a;
    }
    .status-badge.pending {
        background: #fef3c7;
        color: #d97706;
    }

    /* Documents Section */
    .documents-section {
        margin: 32px 0;
        padding: 24px;
        background: #fafef7;
        border-radius: 24px;
        border: 1px solid #eef2f0;
    }
    .section-title {
        display: flex;
        align-items: center;
        gap: 12px;
        margin-bottom: 20px;
    }
    .section-title i {
        width: 32px;
        height: 32px;
        background: #e6f7ec;
        border-radius: 10px;
        display: flex;
        align-items: center;
        justify-content: center;
        color: #16a34a;
        font-size: 1rem;
    }
    .section-title h5 {
        font-size: 1rem;
        font-weight: 700;
        color: #0a2f1f;
        margin: 0;
    }
    .document-list {
        display: flex;
        flex-direction: column;
        gap: 12px;
    }
    .document-item {
        display: flex;
        align-items: center;
        gap: 12px;
        padding: 12px 16px;
        background: white;
        border-radius: 14px;
        text-decoration: none;
        transition: all 0.2s;
        border: 1px solid #eef2f0;
    }
    .document-item:hover {
        transform: translateX(4px);
        border-color: #16a34a;
        box-shadow: 0 2px 8px rgba(22, 163, 74, 0.1);
    }
    .document-item i.fa-file-pdf {
        font-size: 24px;
    }
    .document-item .filename {
        flex: 1;
        font-size: 0.85rem;
        color: #1e293b;
    }
    .document-item i.fa-download {
        color: #94a3b8;
        transition: color 0.2s;
    }
    .document-item:hover i.fa-download {
        color: #16a34a;
    }

    /* Action Buttons */
    .form-actions {
        display: flex;
        justify-content: space-between;
        align-items: center;
        gap: 16px;
        margin-top: 32px;
        padding-top: 24px;
        border-top: 1px solid #eef2f0;
        flex-wrap: wrap;
    }
    .action-buttons-group {
        display: flex;
        gap: 12px;
    }
    .btn-secondary, .btn-approve, .btn-reject {
        display: inline-flex;
        align-items: center;
        gap: 8px;
        padding: 10px 24px;
        border-radius: 12px;
        font-weight: 600;
        font-size: 0.85rem;
        transition: all 0.2s;
        text-decoration: none;
        cursor: pointer;
        border: none;
    }
    .btn-secondary {
        background: white;
        border: 1px solid #e2e8f0;
        color: #475569;
    }
    .btn-secondary:hover {
        border-color: #16a34a;
        color: #16a34a;
        transform: translateY(-2px);
    }
    .btn-approve {
        background: #e6f7ec;
        color: #16a34a;
        border: 1px solid #16a34a;
    }
    .btn-approve:hover {
        background: #16a34a;
        color: white;
        transform: translateY(-2px);
        box-shadow: 0 4px 12px rgba(22, 163, 74, 0.3);
    }
    .btn-reject {
        background: #fee2e2;
        color: #dc2626;
        border: 1px solid #dc2626;
    }
    .btn-reject:hover {
        background: #dc2626;
        color: white;
        transform: translateY(-2px);
        box-shadow: 0 4px 12px rgba(220, 38, 38, 0.3);
    }

    /* Responsive */
    @@media (max-width: 768px) {
        .hero-heading { font-size: 2rem; }
        .form-container { margin-top: -20px; padding: 0 16px; }
        .form-card-header { padding: 20px 24px; flex-direction: column; text-align: center; }
        .form-card-body { padding: 24px; }
        .details-grid { grid-template-columns: 1fr; }
        .form-actions { flex-direction: column; align-items: stretch; }
        .action-buttons-group { flex-direction: column; }
        .btn-secondary, .btn-approve, .btn-reject { justify-content: center; width: 100%; }
    }
</style>