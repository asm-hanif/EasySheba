@{
    ViewData["Title"] = "Register | EasySheba";
}

<div class="register-container">
    <div class="hero-bg-register">
        <i class="fas fa-heart"></i>
        <i class="fas fa-stethoscope"></i>
        <i class="fas fa-pills"></i>
        <i class="fas fa-notes-medical"></i>
        <i class="fas fa-first-aid"></i>
        <i class="fas fa-heartbeat"></i>
    </div>
    <div class="container">
        <div class="row justify-content-center align-items-center min-vh-100">
            <div class="col-md-10 col-lg-8">

                <div class="register-card">

                    <!-- Logo and Header -->
                    <div class="text-center mb-4">
                        <div class="logo-wrapper">
                            <i class="fas fa-hospital-user"></i>
                        </div>
                        <h2 class="register-title">Create Account</h2>
                        <p class="register-subtitle">Join EasySheba and access quality healthcare</p>
                    </div>

                    <!-- Role Selection -->
                    <div class="role-selection">
                        <label class="role-label">
                            <i class="fas fa-user-tag"></i> Select Your Role
                        </label>
                        <div class="role-buttons">
                            <button type="button" class="role-btn" data-role="patient">
                                <i class="fas fa-user"></i>
                                <span>Patient</span>
                            </button>
                            <button type="button" class="role-btn" data-role="hospital">
                                <i class="fas fa-hospital"></i>
                                <span>Hospital Admin</span>
                            </button>
                        </div>
                        <select id="roleSelect" class="role-select-mobile" style="display:none;">
                            <option value="" selected disabled>-- Choose Role --</option>
                            <option value="Patient">👤 Patient</option>
                            <option value="HospitalAdmin">🏥 Hospital Admin</option>
                        </select>
                    </div>

                    <!-- ===================== PATIENT FORM ===================== -->
                    <div id="patientForm" class="form-container" style="display:none;">
                        <div class="form-wrapper">
                            <div class="form-header">
                                <i class="fas fa-user-circle"></i>
                                <h4>Patient Registration</h4>
                                <p>Book appointments with top doctors</p>
                            </div>

                            <form method="post" asp-controller="Account" asp-action="Register">
                                <input type="hidden" name="role" value="Patient" />

                                <div class="row">
                                    <div class="col-12 mb-3">
                                        <label class="form-label">Full Name</label>
                                        <div class="input-group">
                                            <span class="input-icon"><i class="fas fa-user"></i></span>
                                            <input name="fullName" type="text" class="form-control"
                                                   placeholder="Enter your full name" required />
                                        </div>
                                    </div>

                                    <div class="col-12 mb-3">
                                        <label class="form-label">Email Address</label>
                                        <div class="input-group">
                                            <span class="input-icon"><i class="fas fa-envelope"></i></span>
                                            <input name="email" type="email" class="form-control"
                                                   placeholder="Enter your email" required />
                                        </div>
                                    </div>

                                    <div class="col-md-6 mb-3">
                                        <label class="form-label">Password</label>
                                        <div class="input-group">
                                            <span class="input-icon"><i class="fas fa-lock"></i></span>
                                            <input name="password" type="password" class="form-control password-input"
                                                   placeholder="Enter password" required />
                                            <button class="toggle-password" type="button">
                                                <i class="fas fa-eye"></i>
                                            </button>
                                        </div>
                                    </div>

                                    <div class="col-md-6 mb-3">
                                        <label class="form-label">Confirm Password</label>
                                        <div class="input-group">
                                            <span class="input-icon"><i class="fas fa-lock"></i></span>
                                            <input name="confirmPassword" type="password" class="form-control password-input"
                                                   placeholder="Confirm password" required />
                                            <button class="toggle-password" type="button">
                                                <i class="fas fa-eye"></i>
                                            </button>
                                        </div>
                                    </div>
                                </div>

                                <div class="terms-check mb-4">
                                    <label class="checkbox-container">
                                        <input type="checkbox" id="patientTerms" required>
                                        <span class="checkmark"></span>
                                        I agree to the <a href="#">Terms of Service</a> and <a href="#">Privacy Policy</a>
                                    </label>
                                </div>

                                <button type="submit" class="btn-submit w-100">
                                    <i class="fas fa-user-plus"></i> Register as Patient
                                </button>
                            </form>
                        </div>
                    </div>

                    <!-- ===================== HOSPITAL ADMIN FORM ===================== -->
                    <div id="hospitalForm" class="form-container" style="display:none;">
                        <div class="form-wrapper">
                            <div class="form-header hospital-header">
                                <i class="fas fa-hospital"></i>
                                <h4>Hospital Admin Registration</h4>
                                <p>Manage your hospital on EasySheba</p>
                            </div>

                            <form method="post" asp-controller="Account" asp-action="Register"
                                  enctype="multipart/form-data">
                                <input type="hidden" name="role" value="HospitalAdmin" />

                                <div class="row">
                                    <div class="col-md-6 mb-3">
                                        <label class="form-label">Hospital Name</label>
                                        <div class="input-group">
                                            <span class="input-icon"><i class="fas fa-hospital"></i></span>
                                            <input name="hospitalName" type="text" class="form-control"
                                                   placeholder="Enter hospital name" required />
                                        </div>
                                    </div>

                                    <div class="col-md-6 mb-3">
                                        <label class="form-label">Contact Number</label>
                                        <div class="input-group">
                                            <span class="input-icon"><i class="fas fa-phone"></i></span>
                                            <input name="contactNumber" type="text" class="form-control"
                                                   placeholder="Enter contact number" required />
                                        </div>
                                    </div>

                                    <div class="col-12 mb-3">
                                        <label class="form-label">Email Address</label>
                                        <div class="input-group">
                                            <span class="input-icon"><i class="fas fa-envelope"></i></span>
                                            <input name="email" type="email" class="form-control"
                                                   placeholder="Enter email" required />
                                        </div>
                                    </div>

                                    <div class="col-md-6 mb-3">
                                        <label class="form-label">Password</label>
                                        <div class="input-group">
                                            <span class="input-icon"><i class="fas fa-lock"></i></span>
                                            <input name="password" type="password" class="form-control password-input"
                                                   placeholder="Enter password" required />
                                            <button class="toggle-password" type="button">
                                                <i class="fas fa-eye"></i>
                                            </button>
                                        </div>
                                    </div>

                                    <div class="col-md-6 mb-3">
                                        <label class="form-label">Confirm Password</label>
                                        <div class="input-group">
                                            <span class="input-icon"><i class="fas fa-lock"></i></span>
                                            <input name="confirmPassword" type="password" class="form-control password-input"
                                                   placeholder="Confirm password" required />
                                            <button class="toggle-password" type="button">
                                                <i class="fas fa-eye"></i>
                                            </button>
                                        </div>
                                    </div>

                                    <div class="col-12 mb-4">
                                        <label class="form-label">Upload Documents</label>
                                        <div class="upload-area" id="uploadArea">
                                            <i class="fas fa-cloud-upload-alt"></i>
                                            <p>Drag & drop files or click to browse</p>
                                            <small>Hospital License, Trade License, NID (Max 5MB each)</small>
                                            <input name="documents" type="file" class="d-none" id="fileInput" multiple required />
                                        </div>
                                        <div id="fileList" class="file-list"></div>
                                    </div>
                                </div>

                                <div class="terms-check mb-4">
                                    <label class="checkbox-container">
                                        <input type="checkbox" id="hospitalTerms" required>
                                        <span class="checkmark"></span>
                                        I agree to the <a href="#">Terms of Service</a> and <a href="#">Privacy Policy</a>
                                    </label>
                                </div>

                                <button type="submit" class="btn-submit w-100">
                                    <i class="fas fa-hospital-user"></i> Register as Hospital Admin
                                </button>
                            </form>
                        </div>
                    </div>

                    <!-- Login Link -->
                    <div class="login-link-wrapper">
                        <p>Already have an account?</p>
                        <a href="/Account/Login" class="login-link">
                            Login Here <i class="fas fa-arrow-right"></i>
                        </a>
                    </div>

                </div>
            </div>
        </div>
    </div>
</div>

<script>
    // Role selection toggle
    const roleSelect = document.getElementById('roleSelect');
    const patientForm = document.getElementById('patientForm');
    const hospitalForm = document.getElementById('hospitalForm');
    const roleBtns = document.querySelectorAll('.role-btn');

    function showForm(role) {
        if (role === 'patient') {
            patientForm.style.display = 'block';
            hospitalForm.style.display = 'none';
            roleBtns.forEach(btn => {
                if (btn.dataset.role === 'patient') {
                    btn.classList.add('active');
                } else {
                    btn.classList.remove('active');
                }
            });
            roleSelect.value = 'Patient';
        } else if (role === 'hospital') {
            patientForm.style.display = 'none';
            hospitalForm.style.display = 'block';
            roleBtns.forEach(btn => {
                if (btn.dataset.role === 'hospital') {
                    btn.classList.add('active');
                } else {
                    btn.classList.remove('active');
                }
            });
            roleSelect.value = 'HospitalAdmin';
        }
    }

    roleBtns.forEach(btn => {
        btn.addEventListener('click', () => {
            showForm(btn.dataset.role);
        });
    });

    roleSelect.addEventListener('change', (e) => {
        if (e.target.value === 'Patient') {
            showForm('patient');
        } else if (e.target.value === 'HospitalAdmin') {
            showForm('hospital');
        }
    });

    // Password toggle functionality
    document.querySelectorAll('.toggle-password').forEach(button => {
        button.addEventListener('click', function() {
            const input = this.closest('.input-group').querySelector('.password-input');
            const icon = this.querySelector('i');
            if (input.type === 'password') {
                input.type = 'text';
                icon.classList.remove('fa-eye');
                icon.classList.add('fa-eye-slash');
            } else {
                input.type = 'password';
                icon.classList.remove('fa-eye-slash');
                icon.classList.add('fa-eye');
            }
        });
    });

    // File upload handling
    const uploadArea = document.getElementById('uploadArea');
    const fileInput = document.getElementById('fileInput');
    const fileList = document.getElementById('fileList');

    if (uploadArea) {
        uploadArea.addEventListener('click', () => {
            fileInput.click();
        });

        uploadArea.addEventListener('dragover', (e) => {
            e.preventDefault();
            uploadArea.classList.add('dragover');
        });

        uploadArea.addEventListener('dragleave', () => {
            uploadArea.classList.remove('dragover');
        });

        uploadArea.addEventListener('drop', (e) => {
            e.preventDefault();
            uploadArea.classList.remove('dragover');
            fileInput.files = e.dataTransfer.files;
            updateFileList();
        });

        fileInput.addEventListener('change', updateFileList);

        function updateFileList() {
            fileList.innerHTML = '';
            if (fileInput.files.length > 0) {
                Array.from(fileInput.files).forEach(file => {
                    const fileItem = document.createElement('div');
                    fileItem.className = 'file-item';
                    fileItem.innerHTML = `
                        <i class="fas fa-file-pdf"></i>
                        <span>${file.name}</span>
                        <small>(${(file.size / 1024).toFixed(2)} KB)</small>
                    `;
                    fileList.appendChild(fileItem);
                });
            }
        }
    }
</script>

<style>
    /* Reset & Base */
    * {
        margin: 0;
        padding: 0;
        box-sizing: border-box;
    }

    body {
        font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, 'Helvetica Neue', sans-serif;
        overflow-x: hidden;
    }

    .register-container {
        min-height: 100vh;
        background: linear-gradient(135deg, #f8fef8 0%, #eef6ee 100%);
        padding: 60px 0;
        position: relative;
        overflow: hidden;
    }

    .hero-bg-register {
        position: absolute;
        top: 0;
        left: 0;
        width: 100%;
        height: 100%;
        pointer-events: none;
        z-index: 0;
    }

    .hero-bg-register i {
        position: absolute;
        font-size: 40px;
        color: rgba(22, 163, 74, 0.08);
    }

    .hero-bg-register i:nth-child(1) { top: 10%; left: 5%; font-size: 45px; }
    .hero-bg-register i:nth-child(2) { top: 70%; left: 85%; font-size: 50px; }
    .hero-bg-register i:nth-child(3) { top: 80%; left: 15%; font-size: 42px; }
    .hero-bg-register i:nth-child(4) { top: 30%; left: 80%; font-size: 48px; }
    .hero-bg-register i:nth-child(5) { top: 50%; left: 45%; font-size: 55px; }
    .hero-bg-register i:nth-child(6) { top: 85%; left: 70%; font-size: 40px; }

    .register-card {
        background: #ffffff;
        border-radius: 32px;
        padding: 48px;
        box-shadow: 0 25px 50px rgba(0, 0, 0, 0.08);
        position: relative;
        z-index: 1;
    }

    .logo-wrapper {
        width: 80px;
        height: 80px;
        background: #e6f7ec;
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        margin: 0 auto 20px;
    }

    .logo-wrapper i {
        font-size: 40px;
        color: #16a34a;
    }

    .register-title {
        font-size: 2rem;
        font-weight: 800;
        color: #0a2f1f;
        margin-bottom: 8px;
    }

    .register-subtitle {
        font-size: 0.95rem;
        color: #64748b;
    }

    /* Role Selection */
    .role-selection {
        background: #fafef7;
        border-radius: 20px;
        padding: 24px;
        margin-bottom: 32px;
        border: 1px solid #e2e8f0;
    }

    .role-label {
        display: block;
        font-weight: 600;
        color: #0a2f1f;
        margin-bottom: 16px;
        font-size: 0.9rem;
    }

    .role-label i {
        color: #16a34a;
        margin-right: 8px;
    }

    .role-buttons {
        display: flex;
        gap: 16px;
    }

    .role-btn {
        flex: 1;
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 10px;
        padding: 14px 24px;
        background: white;
        border: 2px solid #e2e8f0;
        border-radius: 14px;
        font-size: 1rem;
        font-weight: 600;
        color: #64748b;
        cursor: pointer;
        transition: all 0.3s ease;
    }

    .role-btn i {
        font-size: 1.1rem;
    }

    .role-btn:hover {
        border-color: #16a34a;
        color: #16a34a;
        transform: translateY(-2px);
    }

    .role-btn.active {
        background: #16a34a;
        border-color: #16a34a;
        color: white;
        box-shadow: 0 8px 20px rgba(22, 163, 74, 0.25);
    }

    .role-select-mobile {
        display: none;
        width: 100%;
        padding: 12px;
        border: 1px solid #e2e8f0;
        border-radius: 12px;
        font-size: 1rem;
        color: #0a2f1f;
    }

    /* Form Styles */
    .form-container {
        animation: fadeIn 0.4s ease;
    }

    @@keyframes fadeIn {
        from {
            opacity: 0;
            transform: translateY(10px);
        }
        to {
            opacity: 1;
            transform: translateY(0);
        }
    }

    .form-wrapper {
        background: #ffffff;
        border-radius: 24px;
    }

    .form-header {
        background: linear-gradient(135deg, #16a34a, #15803d);
        color: white;
        border-radius: 20px;
        padding: 24px;
        text-align: center;
        margin-bottom: 28px;
    }

    .form-header i {
        font-size: 48px;
        margin-bottom: 12px;
    }

    .form-header h4 {
        font-size: 1.4rem;
        font-weight: 700;
        margin-bottom: 6px;
    }

    .form-header p {
        font-size: 0.85rem;
        opacity: 0.9;
    }

    .form-label {
        font-size: 0.85rem;
        font-weight: 600;
        color: #0a2f1f;
        margin-bottom: 8px;
        display: block;
    }

    .input-group {
        display: flex;
        align-items: center;
        border: 1px solid #e2e8f0;
        border-radius: 14px;
        background: #fafef7;
        transition: all 0.3s ease;
    }

    .input-group:focus-within {
        border-color: #16a34a;
        box-shadow: 0 0 0 3px rgba(22, 163, 74, 0.1);
    }

    .input-icon {
        padding: 0 14px;
        color: #16a34a;
    }

    .form-control {
        flex: 1;
        padding: 14px 0;
        border: none;
        background: transparent;
        font-size: 0.95rem;
        outline: none;
    }

    .toggle-password {
        background: transparent;
        border: none;
        padding: 0 14px;
        color: #94a3b8;
        cursor: pointer;
        transition: color 0.3s ease;
    }

    .toggle-password:hover {
        color: #16a34a;
    }

    /* Checkbox */
    .checkbox-container {
        display: flex;
        align-items: center;
        gap: 12px;
        cursor: pointer;
        font-size: 0.85rem;
        color: #475569;
    }

    .checkbox-container input {
        display: none;
    }

    .checkmark {
        width: 18px;
        height: 18px;
        border: 2px solid #cbd5e1;
        border-radius: 5px;
        display: inline-block;
        position: relative;
        transition: all 0.2s ease;
    }

    .checkbox-container input:checked + .checkmark {
        background: #16a34a;
        border-color: #16a34a;
    }

    .checkbox-container input:checked + .checkmark::after {
        content: '\f00c';
        font-family: 'Font Awesome 6 Free';
        font-weight: 900;
        position: absolute;
        top: 50%;
        left: 50%;
        transform: translate(-50%, -50%);
        font-size: 10px;
        color: white;
    }

    .checkbox-container a {
        color: #16a34a;
        text-decoration: none;
    }

    .checkbox-container a:hover {
        text-decoration: underline;
    }

    /* Upload Area */
    .upload-area {
        border: 2px dashed #cbd5e1;
        background: #fafef7;
        border-radius: 16px;
        padding: 32px;
        text-align: center;
        cursor: pointer;
        transition: all 0.3s ease;
    }

    .upload-area:hover {
        border-color: #16a34a;
        background: #e6f7ec;
    }

    .upload-area.dragover {
        border-color: #16a34a;
        background: #e6f7ec;
    }

    .upload-area i {
        font-size: 48px;
        color: #16a34a;
        margin-bottom: 12px;
    }

    .upload-area p {
        font-size: 0.9rem;
        color: #475569;
        margin-bottom: 6px;
    }

    .upload-area small {
        font-size: 0.75rem;
        color: #94a3b8;
    }

    .file-list {
        margin-top: 12px;
    }

    .file-item {
        display: flex;
        align-items: center;
        gap: 10px;
        padding: 8px 12px;
        background: #f1f5f9;
        border-radius: 10px;
        margin-bottom: 8px;
        font-size: 0.85rem;
    }

    .file-item i {
        color: #16a34a;
    }

    .file-item span {
        flex: 1;
        color: #0a2f1f;
    }

    .file-item small {
        color: #64748b;
    }

    /* Submit Button */
    .btn-submit {
        background: #16a34a;
        color: white;
        padding: 14px;
        border-radius: 14px;
        font-weight: 700;
        font-size: 1rem;
        border: none;
        cursor: pointer;
        transition: all 0.3s ease;
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 10px;
    }

    .btn-submit:hover {
        background: #15803d;
        transform: translateY(-2px);
        box-shadow: 0 8px 20px rgba(22, 163, 74, 0.3);
    }

    /* Login Link */
    .login-link-wrapper {
        text-align: center;
        margin-top: 32px;
        padding-top: 24px;
        border-top: 1px solid #eef2f0;
    }

    .login-link-wrapper p {
        font-size: 0.9rem;
        color: #64748b;
        margin-bottom: 8px;
    }

    .login-link {
        display: inline-flex;
        align-items: center;
        gap: 8px;
        color: #16a34a;
        text-decoration: none;
        font-weight: 700;
        transition: all 0.3s ease;
    }

    .login-link:hover {
        gap: 12px;
        color: #15803d;
    }

    /* Responsive */
    @@media (max-width: 768px) {
        .register-card {
            padding: 32px;
        }

        .register-title {
            font-size: 1.6rem;
        }

        .role-buttons {
            flex-direction: column;
        }

        .role-btn {
            padding: 12px;
        }

        .form-header {
            padding: 20px;
        }

        .form-header i {
            font-size: 36px;
        }

        .form-header h4 {
            font-size: 1.2rem;
        }
    }

    @@media (max-width: 480px) {
        .register-card {
            padding: 24px;
        }

        .logo-wrapper {
            width: 60px;
            height: 60px;
        }

        .logo-wrapper i {
            font-size: 30px;
        }

        .register-title {
            font-size: 1.4rem;
        }

        .upload-area {
            padding: 24px;
        }
    }
</style>