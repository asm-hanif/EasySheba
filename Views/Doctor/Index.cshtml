@using EasySheba.Data
@using Microsoft.EntityFrameworkCore
@model IEnumerable<EasySheba.Models.Doctor>
@using EasySheba.Services
@inject IAppointmentLimitService LimitService
@inject ApplicationDbContext DbContext

@{
    ViewData["Title"] = "Find Doctors | EasySheba";

    // Get date from query string, default to today
    var dateParam = Context.Request.Query["date"].ToString();
    DateTime selectedDate;
    if (!DateTime.TryParse(dateParam, out selectedDate))
    {
        selectedDate = DateTime.Today;
    }
    // Optional: restrict to today or future only? We'll allow any date.
    var today = selectedDate;
}

<!-- ================= MODERN DOCTOR PAGE ================= -->
<div class="doctor-page-wrapper">
    <!-- Hero Section - Minimal & Bold -->
    <div class="doctor-hero-modern">
        <div class="hero-bg-shapes">
            <div class="shape shape-1"></div>
            <div class="shape shape-2"></div>
            <div class="shape shape-3"></div>
        </div>
        <div class="hero-content-modern">
            <div class="hero-tag">
                <span class="pulse-dot"></span> @Model.Count() Expert Doctors
            </div>
            <h1 class="hero-heading">
                Find Your <span class="green-glow">Perfect</span> Doctor
            </h1>
            <p class="hero-subheading">
                Connect with trusted specialists. Book appointments in seconds.
            </p>
            
            <!-- Search Bar - with Date Picker -->
            <div class="search-bar-modern">
                <div class="search-row">
                    <div class="search-field">
                        <i class="fas fa-user-md"></i>
                        <input type="text" id="searchDoctor" placeholder="Doctor name..." autocomplete="off">
                    </div>
                    <div class="search-field">
    <i class="fas fa-stethoscope"></i>
    <select id="filterSpecialist">
        <option value="">All Specialties</option>
        <option>Cardiology</option>
        <option>Cancer</option>
        <option>Neurology</option>
        <option>Orthopedics</option>
        <option>Pediatrics</option>
        <option>Gynecology</option>
        <option>Dermatology</option>
        <option>Ophthalmology</option>
        <option>Dentistry</option>
        <option>Psychiatry</option>
        <option>General Medicine</option>
        <option>Gastroenterology</option>
        <option>Pulmonology</option>
        <option>Nephrology</option>
        <option>Urology</option>
        <option>Endocrinology</option>
        <option>Rheumatology</option>
        <option>Oncology</option>
        <option>Hematology</option>
        <option>Infectious Disease</option>
        <option>Allergy & Immunology</option>
        <option>Anesthesiology</option>
        <option>Radiology</option>
        <option>Pathology</option>
        <option>Emergency Medicine</option>
        <option>Family Medicine</option>
        <option>Geriatrics</option>
        <option>Sports Medicine</option>
        <option>Plastic Surgery</option>
        <option>Cardiothoracic Surgery</option>
        <option>Neurosurgery</option>
        <option>Vascular Surgery</option>
        <option>Otolaryngology (ENT)</option>
        <option>Physical Medicine & Rehabilitation</option>
        <option>Preventive Medicine</option>
    </select>
</div>
                    <div class="search-field">
                        <i class="fas fa-calendar-day"></i>
                        <input type="date" id="datePicker" value="@today.ToString("yyyy-MM-dd")" min="@DateTime.Today.ToString("yyyy-MM-dd")">
                    </div>
                    <div class="search-field">
                        <i class="fas fa-filter"></i>
                        <select id="filterAvailability">
                            <option value="">Any Availability</option>
                            <option value="available">Available</option>
                            <option value="limited">Limited Slots</option>
                            <option value="booked">Fully Booked</option>
                        </select>
                    </div>
                    <button id="searchBtn" class="search-trigger">
                        <i class="fas fa-search"></i> Find
                    </button>
                </div>
            </div>
        </div>
    </div>

    <!-- Main Content Area -->
    <div class="doctor-main">
        <!-- Alerts -->
        @if (TempData["success"] != null)
        {
            <div class="alert-modern success">
                <i class="fas fa-check-circle"></i>
                <span>@TempData["success"]</span>
                <button class="alert-close" onclick="this.parentElement.remove()">×</button>
            </div>
        }
        @if (TempData["error"] != null)
        {
            <div class="alert-modern error">
                <i class="fas fa-exclamation-circle"></i>
                <span>@TempData["error"]</span>
                <button class="alert-close" onclick="this.parentElement.remove()">×</button>
            </div>
        }

        <!-- Stats & Refresh Bar -->
        <div class="stats-toolbar">
            <div class="stats-bubbles">
                <div class="stat-bubble"><i class="fas fa-user-md"></i> <span>@Model.Count()</span> Doctors</div>
                <div class="stat-bubble"><i class="fas fa-calendar-check"></i> Showing availability for @today.ToString("dd MMM yyyy")</div>
                <div class="stat-bubble"><i class="fas fa-clock"></i> Real-time Slots</div>
            </div>
            <button id="refreshBtn" class="refresh-modern">
                <i class="fas fa-sync-alt"></i> Refresh
            </button>
        </div>

        <!-- Doctors Grid - Modern Card Design -->
        <div class="doctors-grid-modern" id="doctorsGrid">
            @{
                var doctorList = Model.ToList();
            }

            @for (int i = 0; i < doctorList.Count; i++)
            {
                var doctor = doctorList[i];

                var bookedCount = await DbContext.Appointments
                .CountAsync(a => a.DoctorId == doctor.Id
                && a.AppointmentDate.Date == today.Date
                && a.Status == "Approved"
                && a.IsCountedTowardsLimit == true);

                string dayName = today.DayOfWeek.ToString();
                var todayLimit = dayName switch
                {
                    "Monday" => doctor.MondayLimit,
                    "Tuesday" => doctor.TuesdayLimit,
                    "Wednesday" => doctor.WednesdayLimit,
                    "Thursday" => doctor.ThursdayLimit,
                    "Friday" => doctor.FridayLimit,
                    "Saturday" => doctor.SaturdayLimit,
                    "Sunday" => doctor.SundayLimit,
                    _ => doctor.DailyAppointmentLimit
                };

                var availableSlots = Math.Max(0, todayLimit - bookedCount);
                var availableDaysList = doctor.AvailableDays?.Split(", ", StringSplitOptions.RemoveEmptyEntries) ?? new string[0];
                var isAvailableToday = availableDaysList.Contains(dayName);

                // Status styling
                string statusClass = "";
                string statusText = "";
                string statusIcon = "";
                if (!isAvailableToday)
                {
                    statusClass = "status-off";
                    statusText = "Off Today";
                    statusIcon = "fa-calendar-times";
                }
                else if (availableSlots <= 0)
                {
                    statusClass = "status-full";
                    statusText = "Fully Booked";
                    statusIcon = "fa-ban";
                }
                else if (availableSlots <= 3)
                {
                    statusClass = "status-limited";
                    statusText = $"{availableSlots} Slots Left";
                    statusIcon = "fa-hourglass-half";
                }
                else
                {
                    statusClass = "status-available";
                    statusText = $"{availableSlots} Available";
                    statusIcon = "fa-check-circle";
                }

                <div class="doctor-card-modern"
                     data-name="@doctor.Name.ToLower()"
                     data-specialist="@doctor.Specialist.ToLower()"
                     data-available="@availableSlots"
                     data-doctor-id="@doctor.Id">
                    <div class="card-inner-modern">
                        <div class="card-left">
                            <div class="doctor-avatar-modern">
                                @if (!string.IsNullOrEmpty(doctor.ImagePath))
                                {
                                    <img src="@doctor.ImagePath" alt="@doctor.Name">
                                }
                                else
                                {
                                    <div class="avatar-placeholder">
                                        <i class="fas fa-user-md"></i>
                                    </div>
                                }
                                <div class="status-indicator @statusClass">
                                    <i class="fas @statusIcon"></i> @statusText
                                </div>
                            </div>
                        </div>
                        <div class="card-right">
                            <div class="doctor-header-modern">
                                <div>
                                    <h3 class="doctor-name-modern">Dr. @doctor.Name</h3>
                                    <span class="doctor-specialty-modern">@doctor.Specialist</span>
                                    <div class="doctor-badges">
                                        <span class="badge-minimal"><i class="fas fa-graduation-cap"></i> @doctor.Degrees</span>
                                        <span class="badge-minimal"><i class="fas fa-building"></i> @doctor.Department</span>
                                        <span class="badge-minimal"><i class="fas fa-star"></i> @doctor.Experience+ yrs</span>
                                    </div>
                                </div>
                                <div class="fee-modern">
                                    <span class="fee-amount">৳@doctor.Fees</span>
                                    <span class="fee-label">per visit</span>
                                </div>
                            </div>

                            <div class="doctor-info-modern">
                                <div class="info-row">
                                    <i class="fas fa-hospital"></i>
                                    <span>@doctor.HospitalName</span>
                                </div>
                                <div class="info-row">
                                    <i class="fas fa-location-dot"></i>
                                    <span>@doctor.HospitalLocation</span>
                                </div>
                                <div class="info-row">
                                    <i class="fas fa-calendar-alt"></i>
                                    <span>@doctor.AvailableDays</span>
                                </div>
                                <div class="info-row">
                                    <i class="fas fa-clock"></i>
                                    <span>@doctor.AvailableTime</span>
                                </div>
                            </div>

                            <!-- Progress Ring Style -->
                            @if (isAvailableToday && todayLimit > 0)
                            {
                                var percentage = (bookedCount * 100) / todayLimit;
                                <div class="slot-progress-modern">
                                    <div class="progress-text">
                                        <span>Today's bookings</span>
                                        <strong>@bookedCount / @todayLimit</strong>
                                    </div>
                                    <div class="progress-track-modern">
                                        <div class="progress-fill-modern" style="width: @(Math.Min(percentage, 100))%"></div>
                                    </div>
                                </div>
                            }

                            <div class="action-modern">
                                @if (isAvailableToday && availableSlots > 0)
                                {
                                    <a asp-controller="Appointment" asp-action="Book" asp-route-doctorId="@doctor.Id"
                                       class="book-btn-modern" data-doctor-id="@doctor.Id">
                                        <i class="fas fa-calendar-check"></i> Book Now
                                        <i class="fas fa-arrow-right arrow-icon"></i>
                                    </a>
                                }
                                else if (isAvailableToday && availableSlots <= 0)
                                {
                                    <button class="book-btn-modern disabled" disabled>
                                        <i class="fas fa-clock"></i> Sold Out
                                    </button>
                                }
                                else
                                {
                                    <button class="book-btn-modern disabled" disabled>
                                        <i class="fas fa-calendar-week"></i> Not Available
                                    </button>
                                }
                            </div>

                            <!-- Next Available Hint (if not available today) -->
                            @if (!isAvailableToday)
                            {
                                var nextDay = today.AddDays(1);
                                var nextDayName = nextDay.DayOfWeek.ToString();
                                var nextAvailable = doctor.AvailableDays?.Contains(nextDayName) == true;
                                if (nextAvailable)
                                {
                                    <div class="tomorrow-hint">
                                        <i class="fas fa-sun"></i> Available from @nextDay.ToString("dd MMM")
                                    </div>
                                }
                            }
                        </div>
                    </div>
                </div>
            }
        </div>

        @if (!Model.Any())
        {
            <div class="empty-modern">
                <div class="empty-icon">
                    <i class="fas fa-user-md"></i>
                </div>
                <h3>No doctors found</h3>
                <p>Try adjusting your search or check back later</p>
            </div>
        }
    </div>
</div>

@section Scripts {
    <script>
        $(document).ready(function() {
            $('#datePicker').on('change', function() {
                var selectedDate = $(this).val();
                var url = new URL(window.location.href);
                url.searchParams.set('date', selectedDate);
                window.location.href = url.toString();
            });

            function filterDoctors() {
                var searchText = $("#searchDoctor").val().toLowerCase().trim();
                var specialist = $("#filterSpecialist").val().toLowerCase().trim();
                var availability = $("#filterAvailability").val();

                $(".doctor-card-modern").each(function() {
                    var name = ($(this).data("name") || "").toLowerCase().trim();
                    var docSpecialist = ($(this).data("specialist") || "").toLowerCase().trim();
                    var available = parseInt($(this).data("available")) || 0;
                    
                    var statusElement = $(this).find('.status-indicator');
                    var statusText = statusElement.text().toLowerCase();
                    var isNotAvailable = statusText.includes('off') || statusText.includes('not');
                    var isFullyBooked = statusText.includes('full') || statusText.includes('sold');

                    var nameMatch = name.includes(searchText);
                    // Use includes() so "General Medicine" matches "General Medicine (MD)"
                    var specialistMatch = specialist === "" || docSpecialist.includes(specialist);

                    var availabilityMatch = false;
                    if (availability === "") {
                        availabilityMatch = true;
                    } else if (availability === "available") {
                        availabilityMatch = !isNotAvailable && !isFullyBooked && available > 3;
                    } else if (availability === "limited") {
                        availabilityMatch = !isNotAvailable && !isFullyBooked && available > 0 && available <= 3;
                    } else if (availability === "booked") {
                        availabilityMatch = isFullyBooked || available <= 0;
                    }

                    // Debug: log specialist values if not matching (remove in production)
                    if (specialist !== "" && !specialistMatch) {
                        console.log("Selected:", specialist, "Doctor's:", docSpecialist);
                    }

                    if (nameMatch && specialistMatch && availabilityMatch) {
                        $(this).show();
                    } else {
                        $(this).hide();
                    }
                });
            }

            $("#searchDoctor, #filterSpecialist, #filterAvailability, #searchBtn").on("keyup change click", function() {
                filterDoctors();
            });

            $("#refreshBtn").on("click", function() {
                location.reload();
            });
        });
    </script>
}
<style>
    /* ================= MODERN REDESIGN ================= */
    /* Keeping original green color scheme (#16a34a) with fresh modern style */

    * {
        margin: 0;
        padding: 0;
        box-sizing: border-box;
    }

    .doctor-page-wrapper {
        background: #f5f7fb;
        min-height: 100vh;
    }

    /* Hero Section - Modern Minimal */
    .doctor-hero-modern {
        background: linear-gradient(125deg, #ffffff 0%, #f8fafc 100%);
        padding: 60px 5% 80px;
        position: relative;
        overflow: hidden;
    }

    .hero-bg-shapes {
        position: absolute;
        top: 0;
        left: 0;
        width: 100%;
        height: 100%;
