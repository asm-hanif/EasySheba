    }

    .shape-1 {
        width: 400px;
        height: 400px;
        top: -150px;
        right: -100px;
    }

    .shape-2 {
        width: 250px;
        height: 250px;
        bottom: -80px;
        left: 10%;
        background: rgba(22, 163, 74, 0.05);
    }

    .shape-3 {
        width: 180px;
        height: 180px;
        top: 30%;
        left: -60px;
        background: rgba(22, 163, 74, 0.04);
    }

    .hero-content-modern {
        max-width: 1100px;
        margin: 0 auto;
        position: relative;
        z-index: 2;
        text-align: center;
    }

    .hero-tag {
