    .hero-subheading {
        font-size: 1.1rem;
        color: #5a6e8a;
        max-width: 550px;
        margin: 0 auto 40px;
    }

    /* Search Bar - Clean Modern */
    .search-bar-modern {
        max-width: 900px;
        margin: 0 auto;
        background: white;
        border-radius: 60px;
        padding: 8px;
        box-shadow: 0 20px 35px -10px rgba(0, 0, 0, 0.08);
        border: 1px solid rgba(22, 163, 74, 0.15);
    }

    .search-row {
        display: flex;
