@{
    ViewData["Title"] = "Appointment Confirmed | EasySheba";
}

<div class="confirmation-container">
    <div class="hero-bg-confirmation">
        <i class="fas fa-heart"></i>
        <i class="fas fa-stethoscope"></i>
        <i class="fas fa-pills"></i>
        <i class="fas fa-notes-medical"></i>
        <i class="fas fa-first-aid"></i>
        <i class="fas fa-heartbeat"></i>
        <i class="fas fa-check-circle"></i>
        <i class="fas fa-calendar-check"></i>
    </div>

    <div class="container py-5">
        <div class="row justify-content-center">
            <div class="col-md-8 col-lg-6">

                <div class="confirmation-card">
                    <!-- Success Animation -->
                    <div class="success-animation">
                        <div class="checkmark-circle">
                            <i class="fas fa-check"></i>
                        </div>
                        <div class="pulse-ring"></div>
                    </div>

                    <div class="confirmation-content">
                        <h1 class="confirmation-title">Appointment Booked!</h1>
                        <p class="confirmation-message">
                            Your appointment request has been submitted successfully and is now pending approval from the hospital admin.
                        </p>

                        <div class="info-box">
                            <i class="fas fa-clock"></i>
                            <div>
                                <strong>What happens next?</strong>
                                <p>The hospital admin will review your request and approve it within 24 hours. You'll receive a confirmation email once approved.</p>
                            </div>
                        </div>

                        <div class="action-buttons">
                            <a href="/Appointment/MyAppointments" class="btn-primary-custom">
                                <i class="fas fa-calendar-alt"></i> View My Appointments
                            </a>
                            <a href="/" class="btn-secondary-custom">
                                <i class="fas fa-home"></i> Back to Home
                            </a>
                        </div>

                        <div class="notification-note">
                            <i class="fas fa-envelope"></i>
                            <span>You will receive a confirmation email once the appointment is approved.</span>
                        </div>
                    </div>
                </div>

            </div>
        </div>
    </div>
</div>

<style>
    /* Container & Background */
    .confirmation-container {
        min-height: 100vh;
        background: linear-gradient(135deg, #f8fef8 0%, #eef6ee 100%);
        padding: 60px 0;
        position: relative;
        overflow: hidden;
        display: flex;
        align-items: center;
    }

    .hero-bg-confirmation {
        position: absolute;
        top: 0;
        left: 0;
        width: 100%;
        height: 100%;
        pointer-events: none;
        z-index: 0;
    }

    .hero-bg-confirmation i {
        position: absolute;
        font-size: 40px;
        color: rgba(22, 163, 74, 0.06);
    }

    .hero-bg-confirmation i:nth-child(1) { top: 15%; left: 5%; font-size: 45px; }
    .hero-bg-confirmation i:nth-child(2) { top: 70%; left: 85%; font-size: 50px; }
    .hero-bg-confirmation i:nth-child(3) { top: 80%; left: 15%; font-size: 42px; }
    .hero-bg-confirmation i:nth-child(4) { top: 30%; left: 80%; font-size: 48px; }
    .hero-bg-confirmation i:nth-child(5) { top: 50%; left: 45%; font-size: 55px; }
    .hero-bg-confirmation i:nth-child(6) { top: 85%; left: 70%; font-size: 40px; }
    .hero-bg-confirmation i:nth-child(7) { top: 20%; left: 55%; font-size: 38px; }
    .hero-bg-confirmation i:nth-child(8) { top: 65%; left: 25%; font-size: 44px; }

    /* Confirmation Card */
    .confirmation-card {
        background: white;
        border-radius: 32px;
        padding: 48px 40px;
        text-align: center;
        box-shadow: 0 25px 50px rgba(0, 0, 0, 0.08);
        border: 1px solid #eef2f0;
        position: relative;
        z-index: 1;
        animation: fadeInUp 0.6s ease;
    }

    @@keyframes fadeInUp {
        from {
            opacity: 0;
            transform: translateY(40px);
        }
        to {
            opacity: 1;
            transform: translateY(0);
        }
    }

    /* Success Animation */
    .success-animation {
        position: relative;
        width: 100px;
        height: 100px;
        margin: 0 auto 32px;
    }

    .checkmark-circle {
        width: 100px;
        height: 100px;
        background: #e6f7ec;
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        position: relative;
        z-index: 2;
        animation: scaleIn 0.5s ease;
    }

    .checkmark-circle i {
        font-size: 48px;
        color: #16a34a;
        animation: checkmarkPop 0.4s ease 0.2s both;
    }

    .pulse-ring {
        position: absolute;
        top: 0;
        left: 0;
        width: 100%;
        height: 100%;
        border-radius: 50%;
        background: rgba(22, 163, 74, 0.2);
        animation: pulseRing 1.5s ease-out infinite;
        z-index: 1;
    }

    @@keyframes scaleIn {
        from {
            transform: scale(0);
            opacity: 0;
        }
        to {
            transform: scale(1);
            opacity: 1;
        }
    }

    @@keyframes checkmarkPop {
        0% {
            transform: scale(0);
            opacity: 0;
        }
        50% {
            transform: scale(1.2);
        }
        100% {
            transform: scale(1);
            opacity: 1;
        }
    }

    @@keyframes pulseRing {
        0% {
            transform: scale(1);
            opacity: 0.5;
        }
        100% {
            transform: scale(1.5);
            opacity: 0;
        }
    }

    /* Confirmation Content */
    .confirmation-content {
        margin-top: 8px;
    }

    .confirmation-title {
        font-size: 1.8rem;
        font-weight: 800;
        color: #0a2f1f;
        margin-bottom: 12px;
    }

    .confirmation-message {
        font-size: 1rem;
        color: #475569;
        line-height: 1.6;
        margin-bottom: 28px;
    }

    /* Info Box */
    .info-box {
        background: #fafef7;
        border-radius: 16px;
        padding: 20px;
        margin-bottom: 32px;
        display: flex;
        align-items: flex-start;
        gap: 14px;
        text-align: left;
        border: 1px solid #eef2f0;
        transition: all 0.3s ease;
    }

    .info-box:hover {
        border-color: #16a34a;
        transform: translateY(-2px);
    }

    .info-box i {
        font-size: 24px;
        color: #16a34a;
        flex-shrink: 0;
        margin-top: 2px;
    }

    .info-box strong {
        display: block;
        font-size: 0.9rem;
        font-weight: 700;
        color: #0a2f1f;
        margin-bottom: 6px;
    }

    .info-box p {
        font-size: 0.85rem;
        color: #64748b;
        line-height: 1.5;
        margin: 0;
    }

    /* Action Buttons */
    .action-buttons {
        display: flex;
        gap: 16px;
        justify-content: center;
        margin-bottom: 24px;
        flex-wrap: wrap;
    }

    .btn-primary-custom {
        display: inline-flex;
        align-items: center;
        gap: 10px;
        padding: 12px 28px;
        background: #16a34a;
        color: white;
        border-radius: 12px;
        font-weight: 600;
        font-size: 0.9rem;
        text-decoration: none;
        transition: all 0.3s ease;
    }

    .btn-primary-custom:hover {
        background: #15803d;
        transform: translateY(-2px);
        box-shadow: 0 8px 20px rgba(22, 163, 74, 0.3);
        color: white;
        text-decoration: none;
    }

    .btn-secondary-custom {
        display: inline-flex;
        align-items: center;
        gap: 10px;
        padding: 12px 28px;
        background: white;
        color: #16a34a;
        border-radius: 12px;
        font-weight: 600;
        font-size: 0.9rem;
        text-decoration: none;
        border: 1px solid #16a34a;
        transition: all 0.3s ease;
    }

    .btn-secondary-custom:hover {
        background: #16a34a;
        color: white;
        transform: translateY(-2px);
        text-decoration: none;
    }

    /* Notification Note */
    .notification-note {
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 10px;
        padding: 12px 16px;
        background: #f8fafc;
        border-radius: 40px;
        font-size: 0.8rem;
        color: #64748b;
        margin-top: 8px;
    }

    .notification-note i {
        color: #16a34a;
        font-size: 0.9rem;
    }

    /* Responsive Design */
    @@media (max-width: 768px) {
        .confirmation-container {
            padding: 40px 0;
        }

        .confirmation-card {
            padding: 32px 24px;
            margin: 0 16px;
        }

        .confirmation-title {
            font-size: 1.5rem;
        }

        .confirmation-message {
            font-size: 0.95rem;
        }

        .success-animation {
            width: 80px;
            height: 80px;
        }

        .checkmark-circle {
            width: 80px;
            height: 80px;
        }

        .checkmark-circle i {
            font-size: 38px;
        }

        .action-buttons {
            flex-direction: column;
        }

        .btn-primary-custom,
        .btn-secondary-custom {
            justify-content: center;
            width: 100%;
        }

        .info-box {
            padding: 16px;
        }

        .notification-note {
            flex-direction: column;
            text-align: center;
            gap: 6px;
        }
    }

    @@media (max-width: 480px) {
        .confirmation-card {
            padding: 28px 20px;
        }

        .confirmation-title {
            font-size: 1.3rem;
        }

        .info-box {
            flex-direction: column;
            text-align: center;
        }

        .info-box i {
            margin: 0 auto;
        }

        .info-box div {
            text-align: center;
        }
    }
</style>